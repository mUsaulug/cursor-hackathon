# Backend environment (copy to .env — never commit .env)
PORT=8080

# Hugging Face — live DETR + PII detector for anonymizer (optional but recommended)
HF_API_TOKEN=
HF_INFERENCE_BASE_URL=

# OpenRouter — optional prose rewrite only
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Street View — opt-in external imagery (blur-before-inference)
GOOGLE_STREET_VIEW_API_KEY=

# CORS — additional allowed origin (Vercel *.vercel.app is built-in)
ALLOWED_ORIGIN=
