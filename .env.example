# CivicLens Wave 2 — Local environment variables
# Kullanım: cp .env.example .env ve değerleri doldur
# Bu dosya yalnızca şablon; gerçek secret içermez, commit edilebilir.

# ---------------------------------------------------------------------------
# Backend (Go)
# ---------------------------------------------------------------------------

# Hugging Face — anonymizer (yüz/plaka detector) ve vision pipeline için
HF_API_TOKEN=

# OpenRouter — yalnızca rapor prose + opsiyonel metin sinyali (karar yolunda değil)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------------
# PostgreSQL (docker-compose'dan)
# W2-5: report/task/evidence kalıcı yaşam döngüsü
# ---------------------------------------------------------------------------
POSTGRES_DSN=postgres://civiclens:civiclens_dev@localhost:5432/civiclens?sslmode=disable
POSTGRES_PASSWORD=civiclens_dev

# ---------------------------------------------------------------------------
# Redis (docker-compose'dan)
# W2-5: dedup geohash (geo:recent:{geohash}), dashboard cache,
#        idempotency anahtarı (report:hash:{sha}), sayaç cache
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Kafka (docker-compose'dan)
# W2-6: yaşam döngüsü event bus
# Topic'ler otomatik oluşur (KAFKA_AUTO_CREATE_TOPICS_ENABLE=true).
#
# Report topics : report.created, report.anonymized,
#                 report.ai_analyzed, report.dedup_checked
# Task topics   : task.created, task.assigned, task.started,
#                 task.evidence_uploaded, task.ai_verified,
#                 task.completed, task.reopened
# ---------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092

# ---------------------------------------------------------------------------
# Web (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
